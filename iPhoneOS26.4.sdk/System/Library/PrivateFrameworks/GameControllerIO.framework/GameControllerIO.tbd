--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/GameControllerIO.framework/GameControllerIO
current-version:       13.4.9
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    symbols:              [ _GCAdaptiveTriggersServiceClientInterface,
                            _GCAdaptiveTriggersServiceServerInterface,
                            _GCBatteryServiceClientInterface,
                            _GCBatteryServiceServerInterface,
                            _GCDriverClientInterface, _GCDriverServerInterface,
                            _GCGameIntentServiceClientInterface,
                            _GCGameIntentServiceServerInterface,
                            _GCGenericGamepadBatteryDescriptor,
                            _GCIdleServiceClientInterface,
                            _GCIdleServiceServerInterface,
                            _GCLightServiceClientInterface,
                            _GCLightServiceServerInterface,
                            _GCMotionServiceClientInterface,
                            _GCMotionServiceServerInterface,
                            _GCNintendoJoyConFusionGestureServiceClientInterface,
                            _GCNintendoJoyConFusionGestureServiceServerInterface,
                            _hexStringFromByteArray, _isPartnerSupportEnabled ]
    objc-classes:         [ GCGamepadHIDServicePlugin, GCHapticMotor,
                            _GCHapticEvent ]
    objc-ivars:           [ GCGamepadHIDServicePlugin._activated,
                            GCGamepadHIDServicePlugin._batteryClient,
                            GCGamepadHIDServicePlugin._batteryReport,
                            GCGamepadHIDServicePlugin._batteryUserDevice,
                            GCGamepadHIDServicePlugin._bluetoothClassic,
                            GCGamepadHIDServicePlugin._bluetoothLE,
                            GCGamepadHIDServicePlugin._buttonHome,
                            GCGamepadHIDServicePlugin._buttonMenu,
                            GCGamepadHIDServicePlugin._buttonOptions,
                            GCGamepadHIDServicePlugin._buttonSearch,
                            GCGamepadHIDServicePlugin._buttonShare,
                            GCGamepadHIDServicePlugin._cancelHandler,
                            GCGamepadHIDServicePlugin._client,
                            GCGamepadHIDServicePlugin._clientAdded,
                            GCGamepadHIDServicePlugin._currentHapticClipTime,
                            GCGamepadHIDServicePlugin._currentHapticDispatchTime,
                            GCGamepadHIDServicePlugin._daemonConnection,
                            GCGamepadHIDServicePlugin._device,
                            GCGamepadHIDServicePlugin._dispatchQueue,
                            GCGamepadHIDServicePlugin._dispatcher,
                            GCGamepadHIDServicePlugin._gameControllerExtendedState,
                            GCGamepadHIDServicePlugin._gameControllerState,
                            GCGamepadHIDServicePlugin._hapticDispatchFrequency,
                            GCGamepadHIDServicePlugin._hapticDispatchSource,
                            GCGamepadHIDServicePlugin._hapticMotors,
                            GCGamepadHIDServicePlugin._hapticsActive,
                            GCGamepadHIDServicePlugin._idleClient,
                            GCGamepadHIDServicePlugin._idleDispatchSource,
                            GCGamepadHIDServicePlugin._idleTimeoutDuration,
                            GCGamepadHIDServicePlugin._inputEventDelay,
                            GCGamepadHIDServicePlugin._internalQueue,
                            GCGamepadHIDServicePlugin._keyboardEventState,
                            GCGamepadHIDServicePlugin._lastEventTime,
                            GCGamepadHIDServicePlugin._leftThumbstickAxisSnapRadius,
                            GCGamepadHIDServicePlugin._leftThumbstickDeadzoneRadius,
                            GCGamepadHIDServicePlugin._leftThumbstickNoiseBuffer,
                            GCGamepadHIDServicePlugin._loopHapticEvent,
                            GCGamepadHIDServicePlugin._motionSequenceNumber,
                            GCGamepadHIDServicePlugin._motionState,
                            GCGamepadHIDServicePlugin._pendingHapticZeroReports,
                            GCGamepadHIDServicePlugin._prop,
                            GCGamepadHIDServicePlugin._regID,
                            GCGamepadHIDServicePlugin._rightThumbstickAxisSnapRadius,
                            GCGamepadHIDServicePlugin._rightThumbstickDeadzoneRadius,
                            GCGamepadHIDServicePlugin._rightThumbstickNoiseBuffer,
                            GCGamepadHIDServicePlugin._service,
                            GCGamepadHIDServicePlugin._uniqueIdentifier,
                            GCGamepadHIDServicePlugin._usb,
                            GCGamepadHIDServicePlugin._virtualDevice,
                            GCHapticMotor._amplitude, GCHapticMotor._features,
                            GCHapticMotor._frequency, GCHapticMotor._index,
                            GCHapticMotor._name, GCHapticMotor._queuedTransients,
                            _GCHapticEvent._identifier,
                            _GCHapticEvent._intensity, _GCHapticEvent._sharpness,
                            _GCHapticEvent._startTime, _GCHapticEvent._stopped,
                            _GCHapticEvent._transientBeganAsContinuousEvent,
                            _GCHapticEvent._type ]
...
