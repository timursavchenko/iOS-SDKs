                            ASDatabaseCompetitionListEntryEntity,
                            ASDatabaseCompetitionListEntryJournalEntry,
                            ASDatabaseServer, ASDatabseCompetitionEncoder,
                            ASXPCClient ]
    objc-ivars:           [ ASActivitySharingProfileExtension._daemonWakeCoordinator,
                            ASActivitySharingProfileExtension._profile,
                            ASDaemonWakeCoordinator._apsConnection,
                            ASDaemonWakeCoordinator._lastTodayActivitySummary,
                            ASDaemonWakeCoordinator._lastYesterdayActivitySummary,
                            ASDaemonWakeCoordinator._profile,
                            ASDaemonWakeCoordinator._xpcClient,
                            ASDatabaseCompetitionDeletionJournalEntry._friendUUID,
                            ASDatabaseCompetitionDeletionJournalEntry._type,
                            ASDatabaseCompetitionJournalEntry._databaseCompetition,
                            ASDatabaseCompetitionListEntryJournalEntry._competitionList,
                            ASDatabaseServer._client,
                            ASDatabaseServer._fitnessAppBadgeCount,
                            ASDatabaseServer._isDaemonReady,
                            ASDatabaseServer._queue_performWhenDaemonReadyBlocks,
                            ASDatabaseServer._serialQueue,
                            ASDatabaseServer._taskUUID, ASXPCClient._connection ]
