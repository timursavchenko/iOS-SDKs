                            _ASCompetitionScoreKey,
                            _ASCompetitionStartDateComponentsKey,
                            _ASCompetitionTypeKey, _ASDatabaseServerInterface,
                            _ASDatabaseServerTaskIdentifier,
                            _ActivitySharingHealthDaemonVersionNumber,
                            _ActivitySharingHealthDaemonVersionString ]
    objc-classes:         [ ASActivitySharingProfileExtension,
