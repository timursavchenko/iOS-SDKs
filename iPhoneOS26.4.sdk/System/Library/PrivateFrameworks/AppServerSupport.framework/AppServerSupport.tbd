--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/AppServerSupport.framework/AppServerSupport
current-version:       3102.102.1
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    symbols:              [ __launch_get_last_exit_reason_4SB,
                            _launch_get_running_pid_4SB ]
    objc-classes:         [ LASSProperties4RB, OSLaunchdDomain, OSLaunchdError,
                            OSLaunchdJob, OSLaunchdJobExitStatus, OSLaunchdJobInfo,
                            OSLaunchdJobInstanceProperties,
                            OSLaunchdJobProperties ]
    objc-ivars:           [ LASSProperties4RB._additionalProperties,
                            LASSProperties4RB._enablePressuredExit,
                            LASSProperties4RB._enableTransactions,
                            LASSProperties4RB._endpoints,
                            LASSProperties4RB._hostPID,
                            LASSProperties4RB._instance,
                            LASSProperties4RB._keepAlive,
                            LASSProperties4RB._label, LASSProperties4RB._path,
                            LASSProperties4RB._processType,
                            LASSProperties4RB._program,
                            LASSProperties4RB._requestedJetsamPriority,
                            LASSProperties4RB._runAtLoad,
                            LASSProperties4RB._serviceType,
                            LASSProperties4RB._xpcBundle,
                            OSLaunchdDomain._handle, OSLaunchdDomain._type,
                            OSLaunchdJob._domain, OSLaunchdJob._handle,
                            OSLaunchdJob._monitor_handler,
                            OSLaunchdJob._monitor_queue,
                            OSLaunchdJob._monitor_source, OSLaunchdJob._plist,
                            OSLaunchdJobExitStatus._os_reason_code,
                            OSLaunchdJobExitStatus._os_reason_flags,
                            OSLaunchdJobExitStatus._os_reason_namespace,
                            OSLaunchdJobExitStatus._wait4Status,
                            OSLaunchdJobInfo._additionalPropertiesDictionary,
                            OSLaunchdJobInfo._instance,
                            OSLaunchdJobInfo._lastExitStatus,
                            OSLaunchdJobInfo._lastSpawnError,
                            OSLaunchdJobInfo._pid, OSLaunchdJobInfo._program,
                            OSLaunchdJobInfo._removing, OSLaunchdJobInfo._state,
                            OSLaunchdJobInstanceProperties._environmentVariables,
                            OSLaunchdJobInstanceProperties._sandboxContainer,
                            OSLaunchdJobInstanceProperties._sandboxProfile,
                            OSLaunchdJobProperties._abandonCoalition,
                            OSLaunchdJobProperties._additionalProperties,
                            OSLaunchdJobProperties._additionalSubServices,
                            OSLaunchdJobProperties._arguments,
                            OSLaunchdJobProperties._enterprisePersona,
                            OSLaunchdJobProperties._environmentVariables,
                            OSLaunchdJobProperties._joinExistingSession,
                            OSLaunchdJobProperties._lightweightCodeRequirement,
                            OSLaunchdJobProperties._managedByServices,
                            OSLaunchdJobProperties._managedEndpointLaunchIdentifiers,
                            OSLaunchdJobProperties._omitSandboxParameters,
                            OSLaunchdJobProperties._oneShotUUID,
                            OSLaunchdJobProperties._overlay,
                            OSLaunchdJobProperties._personaString,
                            OSLaunchdJobProperties._platform,
                            OSLaunchdJobProperties._processType,
                            OSLaunchdJobProperties._programArguments,
                            OSLaunchdJobProperties._roleAccount,
                            OSLaunchdJobProperties._runLoopType,
                            OSLaunchdJobProperties._sandboxContainer,
                            OSLaunchdJobProperties._sandboxProfile,
                            OSLaunchdJobProperties._serviceType,
                            OSLaunchdJobProperties._spawnConstraint,
                            OSLaunchdJobProperties._uiApplicationClass,
                            OSLaunchdJobProperties._uiApplicationDelegateClass,
                            OSLaunchdJobProperties._watchdogTimeout ]
...
