--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/LiveFS.framework/LiveFS
current-version:       1
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    re-exports:           [ /System/Library/PrivateFrameworks/FSKit.framework/FSKit ]
    symbols:              [ _LISearchFileContentsInclude,
                            _LISearchFileNameContains, _LISearchFileNameEndsWith,
                            _LISearchObjModifiedAfter, _LISearchObjTypeReturnAll,
                            _LISearchObjTypeReturnDirs,
                            _LISearchObjTypeReturnFiles,
                            _LISearchObjTypeReturnLinks,
                            _LISearchObjXattrsInclude,
                            _LISearchObjXattrsToReturn,
                            _LIUpdateNSFileProviderRootContainerItemIdentifier,
                            _LIUpdateNSFileProviderWorkingSetContainerItemIdentifier,
                            _LiveFSAuthCredPasswordKey,
                            _LiveFSAuthCredUsernameKey,
                            _LiveFSFileSystemTypeName,
                            _LiveFSMounterDisplayNameKey,
                            _LiveFSMounterDomainErasable,
                            _LiveFSMounterDomainErrorKey,
                            _LiveFSMounterDomainHidden,
                            _LiveFSMounterDomainStorageKey,
                            _LiveFSMounterMountIDKey,
                            _LiveFSMounterMountStateKey,
                            _LiveFSMounterMountedOnKey,
                            _LiveFSMounterVolumeNameKey,
                            _LiveFSMounterVolumeProviderNameKey,
                            _LiveFSVersionNumber, _LiveFSVersionString,
                            _getBootUUID, _getNSErrorFromLiveFSErrno,
                            _livefs_std_log ]
    objc-classes:         [ FSKitDiskArbHelper, LiveFSAppleDouble,
                            LiveFSAppleDoubleManager, LiveFSClient,
                            LiveFSDiskUnlock, LiveFSGatedWork, LiveFSIDHelper,
                            LiveFSItemPair, LiveFSLRUCache, LiveFSMountClient,
                            LiveFSRBTree, LiveFSServiceClient,
                            LiveFSServiceConnection, LiveFSServiceUserClient,
                            LiveFSUserClient, LiveFSVolume, LiveFSVolumeClient,
                            LiveFSVolumeManager,
                            LiveFSVolumeSearchResultConnector, LiveFSXattrCache,
                            LiveFSXattrCacheEntry, anonymousDaemon,
                            stolenUSBLocalStorageClient ]
    objc-ivars:           [ LiveFSAppleDouble._ADBufferHeaderBytesValid,
                            LiveFSAppleDouble._ADFileAttributes,
                            LiveFSAppleDouble._ADFileErr,
                            LiveFSAppleDouble._ADFileOK,
                            LiveFSAppleDouble._ADFileOpen,
                            LiveFSAppleDouble._ADHeaderBuffer,
                            LiveFSAppleDouble._IOSize,
                            LiveFSAppleDouble._attr_entry,
                            LiveFSAppleDouble._attrhdr,
                            LiveFSAppleDouble._baseFileHandle,
                            LiveFSAppleDouble._baseFileID,
                            LiveFSAppleDouble._emptyResourceFork,
                            LiveFSAppleDouble._emptyfinderinfo,
                            LiveFSAppleDouble._filehdr,
                            LiveFSAppleDouble._finderinfo,
                            LiveFSAppleDouble._lookupFailed,
                            LiveFSAppleDouble._purpose, LiveFSAppleDouble._rawAD,
                            LiveFSAppleDouble._readonly,
                            LiveFSAppleDouble._rsrcfork,
                            LiveFSAppleDouble._weCreatedFile,
                            LiveFSAppleDouble.fileHandle,
                            LiveFSAppleDouble.fileName,
                            LiveFSAppleDouble.manager,
                            LiveFSAppleDouble.parentDirHandle,
                            LiveFSAppleDouble.syncSem,
                            LiveFSAppleDoubleManager._ADAcctiveForBaseHandleSetWaiters,
                            LiveFSAppleDoubleManager._ADActiveForBaseHandleSet,
                            LiveFSAppleDoubleManager._ADActiveForBaseHandleSetCond,
                            LiveFSAppleDoubleManager._ADActiveForBaseHandleSetMutex,
                            LiveFSAppleDoubleManager._ADActiveForBaseHandleSetRWLock,
                            LiveFSAppleDoubleManager._appleDoubleCache,
                            LiveFSAppleDoubleManager._appleDoubleCacheLRUOrder,
                            LiveFSAppleDoubleManager._clientID,
                            LiveFSAppleDoubleManager._maxCacheSize,
                            LiveFSAppleDoubleManager.mount,
                            LiveFSAppleDoubleManager.queue, LiveFSClient.conn,
                            LiveFSGatedWork._neededCount,
                            LiveFSGatedWork._parameter,
                            LiveFSGatedWork._workBlock, LiveFSItemPair._filename,
                            LiveFSItemPair._itemId, LiveFSLRUCache._countLimit,
                            LiveFSLRUCache._mapping, LiveFSLRUCache._usageOrder,
                            LiveFSMountClient.conn, LiveFSMountClient.helper,
                            LiveFSMountClient.provider, LiveFSRBTree._ourData,
                            LiveFSRBTree.btOps, LiveFSRBTree.btree,
                            LiveFSRBTree.ourComparitor,
                            LiveFSServiceConnection._connectedToFSKitd,
                            LiveFSServiceConnection._ourID,
                            LiveFSServiceConnection.mount,
                            LiveFSServiceConnection.ourConnection,
                            LiveFSServiceConnection.setUpdateInterestQueue,
                            LiveFSVolume._currentConnections,
                            LiveFSVolume._hasPersistentFileIDs,
                            LiveFSVolume._renameChangesFileID,
                            LiveFSVolume._workingSetInterest,
                            LiveFSVolume.connectionCount,
                            LiveFSVolume.validConnections,
                            LiveFSVolumeClient._searchCompletionBlocks,
                            LiveFSVolumeClient._searchResultsBlocks,
                            LiveFSVolumeClient._updateHandlers,
                            LiveFSVolumeManager._initDone,
                            LiveFSVolumeManager.delegate,
                            LiveFSVolumeManager.descriptions,
                            LiveFSVolumeManager.l, LiveFSVolumeManager.listeners,
                            LiveFSVolumeSearchResultConnector._active,
                            LiveFSVolumeSearchResultConnector._conn,
                            LiveFSVolumeSearchResultConnector._currentCredits,
                            LiveFSVolumeSearchResultConnector._maxData,
                            LiveFSVolumeSearchResultConnector._maxDelay,
                            LiveFSVolumeSearchResultConnector._ourToken,
                            LiveFSVolumeSearchResultConnector._throttlingActive,
                            LiveFSVolumeSearchResultConnector.condVar,
                            LiveFSVolumeSearchResultConnector.nextReplyDeadline,
                            LiveFSVolumeSearchResultConnector.pendingAttributes,
                            LiveFSVolumeSearchResultConnector.pendingAttributesSize,
                            LiveFSVolumeSearchResultConnector.pendingAttributesValidSize,
                            LiveFSVolumeSearchResultConnector.pendingData,
                            LiveFSVolumeSearchResultConnector.pendingPaths,
                            LiveFSVolumeSearchResultConnector.pendingXAttrs,
                            LiveFSVolumeSearchResultConnector.waiter,
                            LiveFSXattrCache._cacheEntries,
                            LiveFSXattrCache._entryCount,
                            LiveFSXattrCache._entryLifetime,
                            LiveFSXattrCache._maxItemSize,
                            LiveFSXattrCache._maxItems,
                            LiveFSXattrCache._noXattrsPresent,
                            LiveFSXattrCache._noXattrsPresentSetTime,
                            LiveFSXattrCacheEntry._addedTime,
                            LiveFSXattrCacheEntry._lastUsedTime,
                            LiveFSXattrCacheEntry._xattrBytes,
                            LiveFSXattrCacheEntry._xattrSize,
                            anonymousDaemon._clientClass,
                            anonymousDaemon._endpoint,
                            anonymousDaemon._interface,
                            anonymousDaemon._listener, anonymousDaemon._proxy,
                            anonymousDaemon._queue ]
...
