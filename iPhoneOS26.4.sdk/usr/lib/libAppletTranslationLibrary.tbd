                            WuluReaderContext._file18, WuluReaderContext._file1A,
                            WuluReaderContext._file1E,
                            WuluReaderContext._localRecordFormat,
                            WuluReaderContext._localRecords,
                            WuluReaderContext._overdraft,
                            WuluRecord._associatedSerialNumber, WuluRecord._data,
                            WuluRecord._number, WuluRecord._sfi ]
...
